Package: uwot
Title: The Uniform Manifold Approximation and Projection (UMAP) Method
        for Dimensionality Reduction
Version: 0.2.4
Authors@R: c(
    person("James", "Melville", , "jlmelville@gmail.com", role = c("aut", "cre", "cph")),
    person("Aaron", "Lun", role = "ctb"),
